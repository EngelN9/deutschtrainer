{
  "expo": {
    "name": "DeutschTrainer",
    "slug": "deutschtrainer",
    "scheme": "deutschtrainer",
    "version": "0.1.1",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "platforms": ["ios", "android", "web"],
    "plugins": [
      "expo-router",
      [
        "expo-audio",
        {
          "microphonePermission": "允許 DeutschTrainer 使用麥克風錄製你的德語口說練習。",
          "recordAudioAndroid": true,
          "enableBackgroundRecording": false,
          "enableBackgroundPlayback": false
        }
      ],
      "expo-notifications",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2563EB"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "7a303b8b-2fa8-427d-ae85-d40d49c000eb"
      }
    },
    "ios": {
      "bundleIdentifier": "com.deutschtrainer.app",
      "buildNumber": "3",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.deutschtrainer.app",
      "versionCode": 3
    },
    "web": {
      "favicon": "./assets/icon.png"
    }
  }
}
