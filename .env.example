# Public mobile/admin settings
EXPO_PUBLIC_API_BASE_URL=http://localhost:8787
EXPO_PUBLIC_CONTENT_SOURCE=mock
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
NEXT_PUBLIC_API_BASE_URL=http://localhost:8787
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key

# Server-only settings. Never expose these in mobile or browser bundles.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
OPENAI_API_KEY=replace-with-openai-api-key
AI_DAILY_FREE_LIMIT=20
STORAGE_AUDIO_BUCKET=audio-assets
APP_ENV=local
