{
  "name": "deutschtrainer-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev:mobile": "pnpm --filter @deutschtrainer/mobile start",
    "dev:admin": "pnpm --filter @deutschtrainer/admin dev",
    "dev:api": "pnpm --filter @deutschtrainer/api dev",
    "lint": "eslint .",
    "format:check": "prettier --check \"**/*.{js,cjs,mjs,ts,tsx,json,md,yml,yaml}\"",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "jest --runInBand",
    "supabase:start": "supabase start --exclude logflare --ignore-health-check",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset",
    "prepare": "node scripts/setup-husky.cjs"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@jest/globals": "29.7.0",
    "@types/jest": "29.5.14",
    "@types/node": "24.10.1",
    "eslint": "9.39.1",
    "globals": "16.5.0",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "lint-staged": "16.2.7",
    "prettier": "3.9.5",
    "ts-jest": "29.4.11",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0"
  }
}
